    "autoprefixer": "10.4.14",
    "cz-git": "1.11.1",
    "czg": "1.11.1",
    "eslint": "9.21.0",
    "less": "4.2.2",
    "lint-staged": "15.5.0",
    "openapi2ts": "1.1.7",
    "postcss": "8.4.31",
    "postcss-load-config": "5.0.2",
    "protobufjs-cli": "2.0.0",
