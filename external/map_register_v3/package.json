    "deck.gl": "9.1.14",
    "dexie": "3.2.3",
    "element-plus": "2.11.4",
    "fast-diff": "1.3.0",
    "kdbush": "4.0.2",
    "konva": "9.2.2",
    "lodash": "4.17.21",
    "pinia": "2.1.7",
    "popmotion": "11.0.5",
    "protobufjs": "8.0.0",
    "rxjs": "7.8.0",
    "socket.io-client": "4.8.1",
    "tailwindcss": "3.3.1",
    "ua-parser-js": "1.0.38",
