{
  "screen_width": 1920,
  "screen_height": 1080,
  "monitor_index": 1,
  "minimap_crop_x": 24,
  "minimap_crop_y": 32,
  "minimap_crop_width": 260,
  "minimap_crop_height": 260,
  "debug_output_enabled": true,
  "debug_output_dir": "debug_output",
  "kongying_manifest": "data/kongying/manifest.json",
  "max_match_assets": 0,
